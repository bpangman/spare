# ── Plaid ────────────────────────────────────────────────────────────────────
# Get from dashboard.plaid.com after production approval
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox   # sandbox | development | production

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen` or dashboard

# ── Stripe Treasury ───────────────────────────────────────────────────────────
# Provisioned after Stripe Treasury partner approval
# Treasury uses the same Stripe secret key — no separate key needed
# But you'll need your Treasury financial account ID once provisioned:
STRIPE_TREASURY_FINANCIAL_ACCOUNT_ID=fa_...

# ── Endaoment ────────────────────────────────────────────────────────────────
# Get from partnerships@endaoment.org after partner onboarding
ENDAOMENT_CLIENT_ID=your_endaoment_client_id
ENDAOMENT_CLIENT_SECRET=your_endaoment_client_secret
ENDAOMENT_API_URL=https://api.endaoment.org   # or sandbox URL they provide

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
DATABASE_PATH=./cache.db
FRONTEND_URL=https://bpangman.github.io
# For local dev: FRONTEND_URL=http://localhost:5173
